---
// Otimização: Em vez de autoplay logo de cara que pode travar o thread, garantimos que o vídeo carregue leve.
// Adicionamos um "poster" que é uma imagem de capa que carrega imediatamente (LCP ultrarrápido).
// import posterBanner from '../../assets/img/poster-banner.webp'; // Descomente quando o poster for gerado
---

<section class="banner" id="banner">
  {/* preload="metadata" e atributo poster garantem performance na renderização inicial */}
  <video 
    class="banner__video" 
    autoplay 
    muted 
    loop 
    playsinline 
    preload="metadata"
  >
    <source src="/assets/video/banner.mp4" type="video/mp4" />
    Seu navegador não suporta vídeos HTML5.
  </video>
  
  <div class="banner__overlay"></div>
  
  <header>
    <h1 class="banner__titulo">Santo Solar</h1>
    <h2 class="banner__subtitulo">Transforme a luz do sol em economia</h2>
  </header>
  
  <footer>
    <p class="banner__texto">
      Descubra como reduzir até 95% na sua conta de luz com energia solar
      fotovoltaica
    </p>
    <button
      class="botao banner__botao send-whatsapp"
      data-phone="5531993600722"
      data-message="Olá, gostaria de mais informações sobre o seu produto."
    >
      Quero fazer uma cotação
    </button>
  </footer>
</section>



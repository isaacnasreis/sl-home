---
// Aqui abandonamos as classes vazias com background-image no CSS
// e adotamos a tag <Image /> nativa do Astro para otimização LCP

import { Image } from 'astro:assets';
import imgPH from '../../assets/img/ph.jpg';
import imgINS from '../../assets/img/ins.jpg';
import imgOM from '../../assets/img/om.jpg';
---

<section class="servicos container" id="servicos">
  <h2 class="servicos__titulo tituloH2">Serviços</h2>
  
  <div class="servicos__container">
    <article class="servico">
      <div class="servico__img-wrapper">
        <Image src={imgPH} alt="Projeto e Homologação" class="servico__img-element" />
      </div>
      
      <h3 class="servico__titulo tituloH3">Projeto e homologação</h3>
      <ul class="servico__lista">
        <li class="servico__item">Consultoria personalizada</li>
        <li class="servico__item">Projeto fotovoltaico</li>
        <li class="servico__item">Homologação na cemig</li>
      </ul>
      <button class="botao servico__botao send-whatsapp" data-phone="5531993600722" data-message="Olá, gostaria de mais informações sobre o seu produto. O serviço de Projeto e homologação.">
        Orçamento
      </button>
    </article>

    <article class="servico">
      <div class="servico__img-wrapper">
        <Image src={imgINS} alt="Instalação" class="servico__img-element" />
      </div>
      <h3 class="servico__titulo tituloH3">Instalação</h3>
      <ul class="servico__lista">
        <li class="servico__item">Instalação elétrica</li>
        <li class="servico__item">Instalação fotovoltaica</li>
      </ul>
      <button class="botao servico__botao send-whatsapp" data-phone="5531993600722" data-message="Olá, gostaria de mais informações sobre o seu produto. O serviço de Instalação.">
        Orçamento
      </button>
    </article>

    <article class="servico">
      <div class="servico__img-wrapper">
        <Image src={imgOM} alt="Operação e Manutenção" class="servico__img-element" />
      </div>
      <h3 class="servico__titulo tituloH3">Operação e Manutenção</h3>
      <ul class="servico__lista">
        <li class="servico__item">Comissionamento</li>
        <li class="servico__item">Monitoramento</li>
        <li class="servico__item">Limpeza</li>
        <li class="servico__item">Manutenção</li>
      </ul>
      <button class="botao servico__botao send-whatsapp" data-phone="5531993600722" data-message="Olá, gostaria de mais informações sobre o seu produto. O serviço de Operação e Manutenção.">
        Orçamento
      </button>
    </article>
  </div>
</section>

<style>
/* servico-botao.css */
.servico__botao {
  margin: 1.825rem 0.5rem 0 0.5rem;
  font-size: 1.25rem;
}

@media screen and (max-width: 1290px) {
  .servico__botao {
    font-size: 1.15rem;
  }
}

@media screen and (max-width: 1024px) {
  .servico__botao {
    font-size: 1rem;
  }
}

@media screen and (max-width: 768px) {
  .servico__botao {
    margin: 1rem 0.5rem 0 0.5rem;
  }
}

@media screen and (max-width: 560px) {
  .servico__botao {
    padding: 1rem 2rem !important;
    font-size: 0.825rem;
  }
}

/* servico-img.css modificado para tags img reais */
.servico__img-wrapper {
  width: 100%;
  height: 250px;
  overflow: hidden;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}

.servico__img-element {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.servico:hover .servico__img-element {
  transform: scale(1.1);
}

@media screen and (max-width: 768px) {
  .servico__img-wrapper {
    height: 200px;
  }
}
/* servico-item.css */
@media screen and (max-width: 768px) { 
  .servico__item::marker {
    font-size: 0.5rem;
  }
}
/* servico-lista.css */
.servico__lista {
  text-align: left;
  font-size: 1.125rem;
  font-weight: 400; 
  list-style-position: inside;
  padding: 0 1.5rem;
  margin: 0 auto;
}

@media screen and (max-width: 1290px) {
  .servico__lista {
    padding: 0 2rem;
  }
}

@media screen and (max-width: 1024px) {  
  .servico__lista {
     font-size: 1rem;
     font-weight: 300;
     padding: 0 1.5rem;
   }
}

@media screen and (max-width: 768px) { 
  .servico__lista {
    font-size: 1rem;
    font-weight: 300;
    padding: 0 1rem;
  }
}
/* servico-titulo.css */
.servico__titulo {
  color: var(--var-cor-amarelo);
}

@media screen and (max-width: 1290px) {
  .servico__titulo {
    padding: 0 2rem;
  }
}

@media screen and (max-width: 1024px) {  
  .servico__titulo {
    font-size: 1.25rem;
    padding: 0 1.5rem;
  }
}

@media screen and (max-width: 768px) { 
  .servico__titulo {
    font-size: 1rem;
  }
}

@media screen and (max-width: 560px) {
  .servico__titulo {
    font-size: 1.5rem;
    font-weight: 500;
  }
}
/* servico.css */
.servico {
  background: var(--var-cor-branco);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  overflow: hidden;
  text-align: center;
  padding-bottom: 2rem;
  width: calc(33.33% - 2rem);
  transition: var(--transition);
}

.servico:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-lg);
}

@media screen and (max-width: 1290px) {
  .servico {
    width: calc(33.33% - 1rem);
  }
}

@media screen and (max-width: 1024px) {  
  .servico {
    padding-bottom: 1.5rem;
  }
}

@media screen and (max-width: 900px) {
  .servico {
    width: calc(33.33% - 0.5rem);
  }
}

@media screen and (max-width: 768px) { 
  .servico {
    padding-bottom: 1rem;
    gap: 1rem;
    width: calc(33.33% - 0.25rem);
  }
}

@media screen and (max-width: 560px) {
  .servico {
    padding-bottom: 4rem;
    gap: 2rem;
    width: 100%;
  }
}
/* servicos-container.css */
.servicos__container {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

@media screen and (max-width: 560px) {
  .servicos__container {
    flex-direction: column;
    gap: 1.5rem;
  }
}
/* servicos-titulo.css */
.servicos__titulo {
  color: var(--var-cor-azul);
  margin-bottom: 2rem;
}
/* servicos.css */
.servicos {
  margin: 4rem 0;
}

@media screen and (max-width: 768px) {
  .servicos {
    margin: 2.5rem 0;
  }
}
</style>

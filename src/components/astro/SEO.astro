---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
}

const {
  title = "Santo Solar - Energia Solar ao seu alcance",
  description = "Santo Solar. Transforme a luz do sol em economia. Descubra como reduzir até 95% na sua conta de luz com energia solar fotovoltaica.",
  image = "https://santosolar.com.br/assets/img/og-image.png",
  url = "https://santosolar.com.br/"
} = Astro.props;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>

<meta name="description" content={description} />
<meta name="keywords" content="Energia solar, Economia na conta de luz, Santa Luzia, Fotovoltaica, Instalação solar" />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={url} />
<meta property="og:locale" content="pt_BR" />
<meta name="geo.region" content="BR-MG" />
<meta name="geo.placename" content="Santa Luzia" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={image} />

<!-- Favicon -->
<link rel="icon" type="image/png" sizes="32x32" href="../../assets/img/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="../../assets/img/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="../../assets/img/apple-icon-180x180.png" />
<meta name="theme-color" content="#ffffff" />

<!-- Schema.org — Dados Estruturados para SEO Local -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": url + "#organization",
      "name": "Santo Solar",
      "description": description,
      "url": url,
      "image": image,
      "telephone": "+55-31-99360-0722",
      "email": "contato@santosolar.com.br",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Santa Luzia",
        "addressRegion": "MG",
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -19.7697,
        "longitude": -43.8513
      },
      "areaServed": {
        "@type": "State",
        "name": "Minas Gerais"
      },
      "priceRange": "$$",
      "sameAs": [
        "https://www.instagram.com/santo.solar/",
        "https://www.facebook.com/profile.php?id=100068795833695"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Serviços de Energia Solar",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Projeto e Homologação",
              "description": "Consultoria personalizada, projeto fotovoltaico e homologação na CEMIG."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Instalação Fotovoltaica",
              "description": "Instalação elétrica e de sistemas fotovoltaicos residenciais e comerciais."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Operação e Manutenção",
              "description": "Comissionamento, monitoramento, limpeza e manutenção de usinas solares."
            }
          }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Posso compensar os créditos de energia em outro endereço?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Podem sim, desde que os imóveis estejam todos no mesmo CPF ou CNPJ."
          }
        },
        {
          "@type": "Question",
          "name": "Quanto posso economizar na conta de energia?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "É possível economizar até 95% do custo da fatura. Com a geração paga-se apenas algumas taxas como a taxa de disponibilidade e a taxa de iluminação pública."
          }
        },
        {
          "@type": "Question",
          "name": "Qual a durabilidade do sistema?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "O sistema fotovoltaico tem vida útil de 25 a 30 anos, mas com a manutenção correta pode durar muito mais."
          }
        },
        {
          "@type": "Question",
          "name": "É possível financiar o sistema?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sim, atualmente existem diversas linhas de financiamento onde as parcelas ficam igual ou menor ao valor da conta de energia."
          }
        },
        {
          "@type": "Question",
          "name": "O sistema de energia solar funciona durante dias nublados ou chuvosos?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sim, mesmo em dias nublados ou chuvosos o sistema continua gerando, porém com uma pequena redução."
          }
        }
      ]
    }
  ]
})} />

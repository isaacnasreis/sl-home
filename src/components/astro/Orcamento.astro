---
// Componente de Orçamento estático, focado em conversão e acessibilidade
---

<section class="orcamento container" aria-labelledby="orcamento-title">
  <h2 class="tituloH2 orcamento__titulo" id="orcamento-title">Solicite um orçamento</h2>
  
  <form
    class="orcamento__form"
    action="https://formsubmit.co/ajax/contato@santosolar.com.br"
    method="POST"
    data-form-orcamento
    aria-label="Formulário de solicitação de orçamento"
  >
    <div class="orcamento__formInputContainer">
      <label for="nomeOrcamento" class="sr-only">Nome Completo</label>
      <input
        type="text"
        name="nomeOrcamento"
        id="nomeOrcamento"
        placeholder="Nome"
        required
        aria-required="true"
      />
      
      <label for="emailOrcamento" class="sr-only">Endereço de E-mail</label>
      <input
        type="email"
        name="emailOrcamento"
        id="emailOrcamento"
        placeholder="Email"
        required
        aria-required="true"
      />
    </div>
    
    <div class="orcamento__formInputContainer">
      <label for="telOrcamento" class="sr-only">Telefone de contato</label>
      <input
        type="tel"
        name="telOrcamento"
        id="telOrcamento"
        placeholder="Telefone"
        required
        aria-required="true"
      />
      
      <label for="cidadeOrcamento" class="sr-only">Cidade da instalação</label>
      <input
        type="text"
        name="cidadeOrcamento"
        id="cidadeOrcamento"
        placeholder="Cidade"
        required
        aria-required="true"
      />
    </div>
    
    <label for="consumoOrcamento" class="sr-only">Consumo mensal médio</label>
    <input
      type="text"
      name="consumoOrcamento"
      id="consumoOrcamento"
      placeholder="Consumo mensal (kWh)"
      required
      aria-required="true"
      aria-describedby="consumo-descricao"
    />
    <p class="orcamento__descricaoConsumo" id="consumo-descricao">
      Soma do consumo dos últimos 12 meses em kWh dividido por 12 (Dados
      presentes na conta de energia)
    </p>
    
    <label for="comentatiosOrcamento" class="sr-only">Comentários adicionais</label>
    <textarea
      name="comentatiosOrcamento"
      id="comentatiosOrcamento"
      cols="30"
      rows="10"
      placeholder="Comentários"
    ></textarea>
    
    <button
      type="submit"
      class="botao orcamento__botao"
      data-button-orcamento
      aria-label="Enviar solicitação de orçamento"
    >
      Enviar
    </button>
  </form>
</section>

<style>
/* orcamento-botao.css */
.orcamento__botao {
  background: var(--var-cor-azul);
  border-radius: var(--radius-full);
  color: var(--var-cor-branco);
  font-size: 1.25rem;
  padding: 1rem 2rem;
  text-transform: uppercase;
  font-weight: bold;
  border: none;
  cursor: pointer;
  transition: var(--transition);
  box-shadow: var(--shadow-md);
}

.orcamento__botao:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 15px -3px rgba(30, 38, 109, 0.5);
  background: var(--var-cor-azul-claro);
}

@media screen and (max-width: 1290px) {
  .orcamento__botao {
    font-size: 1.25rem;
  }
}

@media screen and (max-width: 560px) {
  .orcamento__botao {
    margin: 0 auto;
    width: 35%;
  }
}
/* orcamento-descricaoConsumo.css */
.orcamento__descricaoConsumo {
  font-size: 0.875rem;
  position: relative;
  bottom: 0.5rem;
}
/* orcamento-form.css */
.orcamento__form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin: 1rem auto 0 auto;
  width: 50%;
}

.orcamento__form input, .orcamento__form textarea {
  border: none;
  border-radius: var(--radius-md);
  padding: 1rem 1.25rem;
  box-shadow: var(--shadow-sm);
  outline: none;
}
.orcamento__form input:focus, .orcamento__form textarea:focus {
  box-shadow: 0 0 0 2px var(--var-cor-azul);
}

#nomeOrcamento, #cidadeOrcamento {
  width: 50%;
}

#emailOrcamento, #telOrcamento {
  width: 45%;
}

@media screen and (max-width: 1290px) {
  .orcamento__form {
    gap: 1.25rem;
    width: 80%;
  }
  
  .orcamento__form input, .orcamento__form textarea {
    padding:1rem;
  }
}

@media screen and (max-width: 560px) {
  .orcamento__form {
    width: 100%;
  }

  .orcamento__form input, .orcamento__form textarea {
    padding: 1.5rem;
  }

  #nomeOrcamento, #cidadeOrcamento {
    width: 100%;
  }
  
  #emailOrcamento, #telOrcamento {
    width: 100%;
  }
}
/* orcamento-formInputContainer.css */
.orcamento__formInputContainer {
  display: flex;
  flex-wrap: nowrap;
  gap: 1.5rem;
  justify-content: space-between;
}

@media screen and (max-width: 1290px) {
  .orcamento__formInputContainer { 
    gap: 1.5rem;
  }
}

@media screen and (max-width: 560px) {
  .orcamento__formInputContainer {
    flex-direction: column;
  }
}
/* orcamento-titulo.css */
.orcamento__titulo {
  color: var(--var-cor-azul);
  margin-bottom: 2rem;
}
/* orcamento.css */
.orcamento {
  background: var(--var-cor-amarelo);
  padding: 4rem 1rem;
}

</style>
